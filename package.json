{
  "name": "digital-garden",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prebuild": "tsx scripts/prebuild.ts",
    "dev": "npm run prebuild && concurrently -n vite,watch -c cyan,yellow \"vite\" \"nodemon --watch content -e md,mdx,yaml --exec npm run prebuild\"",
