    "chess.js": "^1.4.0",
    "d3": "^7.9.0",
    "flexsearch": "^0.8.212",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "pixi.js": "^8.16.0",
    "react": "^19.0.0",
    "react-chessboard": "^5.10.0",
    "react-dom": "^19.0.0",
    "rehype-autolink-headings": "^7.1.0",
